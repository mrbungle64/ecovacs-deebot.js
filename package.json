{
  "name": "ecovacs-deebot",
  "version": "1.0.0-alpha.0",
  "description": "Library for running Ecovacs Deebot vacuum cleaner robots",
  "main": "index.js",
  "types": "./types/index.d.ts",
  "scripts": {
    "test": "NODE_ENV=test node --test",
    "test_windows": "SET NODE_ENV=test && node --test",
    "test:coverage": "NODE_ENV=test node --test --test-coverage",
    "appTest": "NODE_ENV=dev node example/app2.js",
    "exportTypes": "node_modules/typescript/bin/tsc --declaration --allowJs --emitDeclarationOnly --resolveJsonModule --outDir types",
    "exportAndCheckTypes": "node_modules/typescript/bin/tsc --declaration --allowJs --emitDeclarationOnly --resolveJsonModule --checkJs --outDir types"
  },
  "keywords": [
    "ecovacs",
    "deebot",
    "yeedi",
    "ozmo",
    "vacuum",
    "robot",
    "airbot",
    "air purifier",
    "smart home",
    "home automation"
  ],
  "author": "Sascha Hölzel",
  "license": "GPL-3.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrbungle64/ecovacs-deebot.js.git"
  },
  "dependencies": {
    "axios": "1.16.0",
    "chalk": "4.1.2",
    "lzma": "2.3.2",
    "mqtt": "5.15.1",
    "uniqid": "5.4.0"
  },
  "optionalDependencies": {
    "canvas": "3.2.3"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@types/node": "^25.6.0",
    "eslint": "^8.57.1",
    "globals": "^15.15.0",
    "node-machine-id": "^1.1.12",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.6.0"
  }
}
